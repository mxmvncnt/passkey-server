# DO NOT MODIFY THIS FILE. COPY IT AND NAME IT SOMETHING ELSE

# Name of the config (displayed as a log at startup)
CONFIG_NAME=dev

# debug, info, warn, error, fatal
LOG_LEVEL=debug

SERVER_HOST=localhost
SERVER_PORT=9090

# PostgreSQL configuration.
DB_USER="postgres"
DB_PASS="password"
DB_PORT="5432"
DB_HOST="localhost"
DB_NAME="passkey-server"

# Comma separated list of the frontend URLs that the passkeys will need to be accepted from. You may need to add Android and iOS specific strings here.
WEBAUTHN_ORIGINS=localhost,http://localhost

# top-level domain of your project/service (ex: example.com)
WEBAUTHN_RPID=localhost

# Name that may be displayed on users devices when adding a passkey (you can use the name of your project)
WEBAUTHN_DISPLAYNAME=passkey-server